{
  "manifest_version": 3,
  "name": "Instagram Video Controls",
  "version": "1.0.0",
  "description": "Adiciona controles de vídeo ao Instagram: voltar, avançar, velocidade e mais.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["*://*.instagram.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
